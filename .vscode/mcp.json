{
  "servers": {
    "angular": {
      "command": "ng",
      "args": ["mcp"]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "awesome-copilot": {
      "command": "npx",
      "args": [
        "-y",
        "awesome-copilot-mcp",
        "start"
      ]
    }
  }
}
